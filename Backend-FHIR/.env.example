# Claude API
ANTHROPIC_API_KEY=sk-ant-api03-...

# InterSystems IRIS connection (DB-API — for vector search)
IRIS_HOST=localhost
IRIS_PORT=1972
IRIS_NAMESPACE=USER
IRIS_USER=_SYSTEM
IRIS_PASSWORD=SYS

# InterSystems IRIS FHIR endpoint
# Format: http://<host>:<web-port>/fhir/r4
# Default from docker-compose: http://localhost:32783/fhir/r4
IRIS_FHIR_URL=http://localhost:32783/fhir/r4
